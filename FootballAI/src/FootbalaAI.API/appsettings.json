{
  "ConnectionStrings": {
    "Default": "Server=localhost;Database=FootballAI;Trusted_Connection=True;TrustServerCertificate=True;",
    "Hangfire": "Server=localhost;Database=FootballAI_Hangfire;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_SECURE_KEY_AT_LEAST_32_CHARACTERS_LONG",
    "Issuer": "FootballAI",
    "Audience": "FootballAI.Client",
    "ExpiryMinutes": 60
  },
  "Storage": {
    "Provider": "Azure",
    "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net",
    "Container": "footballai-videos"
  },
  "ML": {
    "YoloModelPath": "Models/yolov8n.onnx",
    "BallModelPath": "Models/ball_detector.onnx",
    "ConfidenceThreshold": 0.5,
    "FrameExtractionFps": 5
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://app.footballai.com"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
 